# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ML Model Configuration
DEVICE=cpu
# Options: cpu, cuda
# GPU recommended for production

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Audio Processing
AUDIO_SAMPLE_RATE=4000
AUDIO_MAX_DURATION=10
AUDIO_MAX_SIZE_MB=5

# API Configuration
API_WORKERS=2
RELOAD=false
# Set RELOAD=true only for development

# Monitoring & Analytics (optional)
# SENTRY_DSN=
# DATADOG_API_KEY=

# Database (optional, for future use)
# DATABASE_URL=postgresql://user:password@localhost/cardioai

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
API_RATE_LIMIT=100
# Requests per minute per IP

# Flutter App Configuration
FLUTTER_API_ENDPOINT=http://localhost:8000
FLUTTER_API_TIMEOUT=30000
# Milliseconds

